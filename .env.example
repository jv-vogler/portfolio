# =============================================================================
# Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#
#   cp .env.example .env.local
#
# Never commit .env.local — it is git-ignored.
# =============================================================================

# ---------------------------------------------------------------------------
# Site URL (used for metadata, sitemap, OG images)
# ---------------------------------------------------------------------------
# Production: your Vercel production domain
# Development: leave empty to default to https://jvvogler.com
NEXT_PUBLIC_BASE_URL=

# ---------------------------------------------------------------------------
# Resend (contact form email delivery)
# ---------------------------------------------------------------------------
# API key from https://resend.com/api-keys
RESEND_API_KEY=

# Recipient email address for contact form submissions
CONTACT_EMAIL_TO=

# Sender email address
# Development: use onboarding@resend.dev (Resend sandbox)
# Production: use a verified domain address, e.g. contact@yourdomain.com
CONTACT_EMAIL_FROM=onboarding@resend.dev

# ---------------------------------------------------------------------------
# Google Analytics 4 (optional)
# ---------------------------------------------------------------------------
# GA4 measurement ID from https://analytics.google.com
# Only active in production — omit or leave empty to disable.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ---------------------------------------------------------------------------
# PayloadCMS (Content Management System)
# ---------------------------------------------------------------------------
# PostgreSQL database connection string
# Development: local Docker Postgres (see docker-compose.yml)
# Production: auto-provided by Vercel Neon Postgres integration
POSTGRES_URL=postgresql://postgres@127.0.0.1:54320/portfolio-db

# Secret key for encrypting PayloadCMS cookies and JWT tokens
# Generate a secure random string (32+ characters)
# Example: openssl rand -base64 32
PAYLOAD_SECRET=
